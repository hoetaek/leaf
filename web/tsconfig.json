{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "types": ["node", "react", "react-dom"]
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "vite.config.js", "vitest.config.js", "eslint.config.js"]
}
