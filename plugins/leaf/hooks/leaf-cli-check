#!/usr/bin/env bash
# SessionStart hook for the leaf plugin.
#
# The plugin ships the LEAF skills, but the skills drive a repo-local workspace
# through the `leaf` CLI (a separate native binary). A plugin cannot install a
# system binary, so this hook only *checks* for it and *guides* installation.
# It never auto-installs and never blocks the session (always exits 0).

set -u

if command -v leaf >/dev/null 2>&1; then
    # CLI present — stay silent so sessions are not noisy.
    exit 0
fi

cat <<'MSG'
⚠️  leaf CLI not found on PATH.

The LEAF skills give the workflow its method; the `leaf` CLI gives that workflow
a repo-local body (the .leaf/ workspace). Install it to use the skills fully:

  brew install hoetaek/tap/leaf
  # or
  cargo install --git https://github.com/hoetaek/leaf
  # or see https://github.com/hoetaek/leaf for release binaries
MSG

exit 0
